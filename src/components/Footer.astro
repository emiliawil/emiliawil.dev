---
import { SOCIAL_LINKS } from "../data/constants";
---

<footer>
	<div class="container">
		<p class="copy">&copy; {new Date().getFullYear()} Emilia Williamson</p>
		<ul>
			{SOCIAL_LINKS.map((link) => (
				<li><a href={link.href} target="_blank" rel="noopener noreferrer">{link.name}</a></li>
			))}
		</ul>
	</div>
</footer>

<style>
	footer {
		border-top: 2px solid var(--ink);
	}

	.container {
		width: 100%;
		max-width: var(--container);
		margin: 0 auto;
		padding: 1.5rem 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.copy {
		margin: 0;
		color: var(--muted);
		font-size: 0.9rem;
	}

	ul {
		list-style: none;
		display: flex;
		gap: 1.25rem;
		padding: 0;
		margin: 0;
	}

	li {
		margin: 0;
	}

	a {
		font-size: 0.9rem;
		font-weight: 600;
		border-bottom: 2px solid transparent;
		padding-bottom: 2px;
	}

	li:nth-child(1) a:hover { color: var(--blue); border-bottom-color: var(--blue); }
	li:nth-child(2) a:hover { color: var(--magenta); border-bottom-color: var(--magenta); }
	li:nth-child(3) a:hover { color: var(--teal); border-bottom-color: var(--teal); }
	li:nth-child(4) a:hover { color: var(--rust); border-bottom-color: var(--rust); }
</style>
