---
import { SOCIAL_LINKS } from "../data/constants";
---

<footer>
    <div class="container">
        <p>&copy; {new Date().getFullYear()} Emilia Williamson</p>
        <ul>
            {SOCIAL_LINKS.map((link) => (
                <li><a href={link.href} target="_blank" rel="noopener noreferrer">{link.name}</a></li>
            ))}
        </ul>
    </div>
</footer>

<style>
    .container {
        max-width: 900px;
        margin: 0 auto;
    }
    footer {
        text-align: center;
        padding: 2rem 1rem;
        background-color: #f0f0f0;
    }

    footer p {
        margin: 0 0 1rem;
        color: #666;
        font-size: 0.9rem;
    }

    footer ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        justify-content: center;
        gap: 1.5rem;
    }

    footer a {
        color: #1a1a1a;
        text-decoration: none;
        font-weight: 500;
    }

    footer a:hover {
        text-decoration: underline;
    }