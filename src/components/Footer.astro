---
import { SOCIAL_LINKS } from "../data/constants";
---

<script src="https://soc-webring.netlify.app/webring.js" crossorigin></script>


<footer>
	<div class="container">
		<div class="content">
			<p class="copy">&copy; {new Date().getFullYear()} Emilia Williamson</p>
			<ul>
				{SOCIAL_LINKS.map((link) => (
					<li><a href={link.href} target="_blank" rel="noopener noreferrer">{link.name}</a></li>
				))}
			</ul>
		</div>
	<soc-webring-widget src="https://soc-webring.netlify.app/members.json" variant="vertical"></soc-webring-widget>
	</div>
</footer>

<style>
	footer {
    background-color: var(--yellow);
	}

	.container {
		max-width: var(--container);
		margin: 0 auto;
		padding: 1.5rem 1.25rem;
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.content {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
	}

	.copy {
		margin: 0;
		color: var(--text);
		font-size: 0.9rem;
	}

	ul {
		list-style: none;
		display: flex;
		column-gap: 1.25rem;
		padding: 0;
		margin: 0;
		flex-wrap: wrap;
		min-width: 0;
	}

	li {
		margin: 0;
	}

	a {
		font-size: 0.9rem;
		font-weight: 600;
		border-bottom: 2px solid transparent;
		padding-bottom: 2px;
	}

    a:hover {
        color: var(--text);
        border-bottom-color: var(--text);
    }
</style>
