---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
	title?: string;
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=Inter:wght@400;500&display=swap"
		/>
		<title>
			{Astro.props.title
				? `${Astro.props.title} | Emilia Williamson`
				: 'Emilia Williamson - Full Stack Developer'}
		</title>
	</head>
	<body>
		{Astro.props.title === "Home" ? (
			<slot />
		) : (
			<>
				<Header />
				<main><slot /></main>
				<Footer />
			</>
		)}
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		box-sizing: border-box;
	}

	body {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		font-family: 'Fraunces', serif;
		color: #1a1a1a;
	}

	main {
		flex: 1;
		max-width: 900px;
		margin: 0 auto;
		padding: 2rem1rem;
	}
</style>
