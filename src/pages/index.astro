---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import WritingFeed from '../components/WritingFeed.astro';
import profilePic from '../assets/profile-pic.png';
---

<Layout title="Home">
    <div class="container">
        <div class="content">
            <h1>Emilia Williamson</h1>
            <span class="job-title">Software Engineer</span>
            <div class="profile-wrap">
                <Image
                    src={profilePic}
                    alt="A profile photo of Emilia Williamson"
                    class="profile-image"
                    width={220}
                    height={220}
                    densities={[1.5, 2]}
                    loading="eager"
                    fetchpriority="high"
                />
            </div>
            <p>Welcome! I'm Emilia, a full stack web developer based in the UK.</p>
            <p>This website is primarily a place for me to share my thoughts on tech topics, but I also want to use it as a space to share other things I'm interested in, like literature, philosophy and media criticism.</p>
            <p><strong>What next?</strong> See my <a href="/work">work</a>, find out what I'm up to <a href="/now">now</a>, or learn a bit more <a href="/about">about me</a>. You can also check out some of my <a href="/writing">writing</a>.</p>

            <h2>Recent posts</h2>
            <WritingFeed limit={3} compact />
        </div>
    </div>
</Layout>

<style>
    :global(main) {
        display: flex;
        flex-direction: column;
    }
    .container {
        display: flex;
        flex-direction: column;
        justify-content: center;
        flex: 1;
    }
    .job-title {
        font-size: 1.5rem;
        font-family: var(--font-serif);
        font-weight: 600;
        font-variation-settings: "opsz" 24;
        color: var(--accent);
        margin-top: -0.5rem;
        margin-bottom: 1.5rem;
        display: inline-block;
    }

    .profile-wrap {
        float: right;
        position: relative;
        width: 220px;
        margin: 0 0 1.5rem 2rem;
    }

    .profile-image {
        width: 220px;
        height: 220px;
        border-radius: 50%;
        object-fit: cover;
        display: block;
        border: 10px solid white;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    .burst {
        position: absolute;
        top: 0px;
        right: -10px;
        width: 64px;
        height: 64px;
        transform: rotate(-8deg);
    }

    h1 {
        margin-bottom: 0.25rem;
    }
    h2 {
        clear: right;
    }

    @media (max-width: 36rem) {
        .profile-wrap {
            float: none;
            margin: 1rem auto;
            width: 220px;
        }
    }

</style>
