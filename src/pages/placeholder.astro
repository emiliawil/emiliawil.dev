---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
	<main class="home">
		<div class="container">
			<h1>Emilia Williamson</h1>
			<p class="role">Full Stack Developer</p>
			<ul>
				<li><a href="https://www.linkedin.com/in/emiliawil">LinkedIn</a></li>
				<li><a href="https://github.com/emiliawil">GitHub</a></li>
				<li><a href="https://bsky.app/profile/emiliawil.dev">Bluesky</a></li>
				<li><a href="mailto:emiliawilliamson@pm.me">Email</a></li>
				<li><a href="/cv.pdf" download>CV ⤓</a></li>
			</ul>
		</div>
	</main>
</Layout>

<style>
	.home {
		min-height: 100dvh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 2rem 1.25rem;
	}

	.container {
		max-width: 32rem;
		margin-left: clamp(1.25rem, 20vw, 12rem);
	}

	h1 {
		font-size: clamp(2.5rem, 6vw, 4rem);
		margin: 0 0 0.25rem;
	}

	.role {
		font-family: var(--font-serif);
		font-weight: 400;
		font-size: 1.25rem;
		font-variation-settings: 'opsz' 24;
		color: var(--muted);
		letter-spacing: -0.005em;
		margin: 0 0 2rem;
	}

	ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	li {
		margin: 0.4rem 0;
	}
</style>
