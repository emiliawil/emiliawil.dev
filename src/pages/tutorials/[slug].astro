---
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";
import { isPublished } from "../../lib/content";

export async function getStaticPaths() {
    const entries = await getCollection("tutorials", isPublished);
    return entries.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { difficulty, duration } = entry.data;
---

<PostLayout
    title={entry.data.title}
    date={entry.data.date}
    description={entry.data.description}
    tags={entry.data.tags}
>
    <Fragment slot="meta">
        {difficulty && <><span class="dot">·</span><span class="chip">{difficulty}</span></>}
        {duration && <><span class="dot">·</span><span>{duration}</span></>}
    </Fragment>

    <Content />
</PostLayout>

<style>
    .chip {
        text-transform: capitalize;
    }
</style>
